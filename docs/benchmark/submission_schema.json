{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gongahkia/chiyoda/docs/benchmark/submission_schema.json",
  "title": "Chiyoda benchmark submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suite",
    "submitter",
    "policy_hash",
    "config_hash",
    "env_version",
    "seed_set",
    "overall",
    "scenarios"
  ],
  "properties": {
    "schema_version": {
      "const": "chiyoda-benchmark-submission-v1"
    },
    "suite": {
      "enum": ["v1", "v2", "v3"]
    },
    "submitter": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{16,64}$"
    },
    "config_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{16,64}$"
    },
    "env_version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chiyoda", "python", "platform"],
      "properties": {
        "chiyoda": {
          "type": "string",
          "minLength": 1
        },
        "python": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "seed_set": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "integer"
      }
    },
    "overall": {
      "$ref": "#/$defs/score_block"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario_score"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "score_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mean_score",
        "score_ci_low",
        "score_ci_high",
        "run_count",
        "tier"
      ],
      "properties": {
        "mean_score": {
          "type": "number"
        },
        "score_ci_low": {
          "type": "number"
        },
        "score_ci_high": {
          "type": "number"
        },
        "run_count": {
          "type": "integer",
          "minimum": 1
        },
        "tier": {
          "enum": ["smoke", "official"]
        }
      }
    },
    "scenario_score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario",
        "mean_score",
        "score_ci_low",
        "score_ci_high",
        "seeds_used",
        "run_count"
      ],
      "properties": {
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "mean_score": {
          "type": "number"
        },
        "score_ci_low": {
          "type": "number"
        },
        "score_ci_high": {
          "type": "number"
        },
        "seeds_used": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "integer"
          }
        },
        "run_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
