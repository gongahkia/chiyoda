{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gibson.local/schemas/structure.schema.json",
  "title": "Gibson Structure",
  "type": "object",
  "required": [
    "seed",
    "size",
    "layers",
    "metadata",
    "grid",
    "rooms",
    "transit_graph",
    "district_lifecycle",
    "macro_massing",
    "meso_placements",
    "micro_details",
    "path_analysis",
    "route_simulation",
    "resource_networks",
    "hazard_zones",
    "failure_zones",
    "rule_packs",
    "factions",
    "temporal_state",
    "narrative_landmarks"
  ],
  "properties": {
    "seed": {
      "type": "string",
      "pattern": "^[A-Z0-9]{8}$"
    },
    "size": {
      "type": "integer",
      "minimum": 1
    },
    "layers": {
      "type": "integer",
      "minimum": 1
    },
    "metadata": {
      "type": "object",
      "required": ["schema_version", "profile", "occupied_cell_ratio"],
      "properties": {
        "schema_version": {
          "const": "gibson.structure.v16"
        },
        "profile": {
          "type": "string"
        },
        "occupied_cell_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "grid": {
      "type": "array"
    },
    "rooms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/room"
      }
    },
    "transit_graph": {
      "type": "object",
      "required": ["nodes", "edges", "attachments"],
      "properties": {
        "nodes": {
          "type": "array"
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/route"
          }
        },
        "attachments": {
          "type": "array"
        }
      }
    },
    "district_lifecycle": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "district",
          "age_years",
          "maintenance_level",
          "occupancy_pressure",
          "control_stability",
          "decay_bias",
          "repair_bias",
          "security_bias",
          "density_bias"
        ],
        "properties": {
          "district": { "type": "string" },
          "age_years": { "type": "integer", "minimum": 0 },
          "maintenance_level": { "type": "number", "minimum": 0, "maximum": 1 },
          "occupancy_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
          "control_stability": { "type": "number", "minimum": 0, "maximum": 1 },
          "decay_bias": { "type": "number", "exclusiveMinimum": 0 },
          "repair_bias": { "type": "number", "exclusiveMinimum": 0 },
          "security_bias": { "type": "number", "exclusiveMinimum": 0 },
          "density_bias": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "macro_massing": {
      "type": "array"
    },
    "meso_placements": {
      "type": "array"
    },
    "micro_details": {
      "type": "array"
    },
    "route_simulation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "route_id",
          "civilian_density",
          "security_pressure",
          "blackout_risk",
          "market_congestion",
          "evacuation_viability",
          "active_phase_ids"
        ],
        "properties": {
          "route_id": { "type": "integer", "minimum": 0 },
          "civilian_density": { "type": "number", "minimum": 0, "maximum": 1 },
          "security_pressure": { "type": "number", "minimum": 0, "maximum": 1 },
          "blackout_risk": { "type": "number", "minimum": 0, "maximum": 1 },
          "market_congestion": { "type": "number", "minimum": 0, "maximum": 1 },
          "evacuation_viability": { "type": "number", "minimum": 0, "maximum": 1 },
          "active_phase_ids": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "resource_networks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "source", "sink", "route_ids", "capacity", "load", "overloaded", "outage", "reroute_route_ids"],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "kind": { "type": "string" },
          "source": { "$ref": "#/$defs/point3" },
          "sink": { "$ref": "#/$defs/point3" },
          "route_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "capacity": { "type": "number", "exclusiveMinimum": 0 },
          "load": { "type": "number", "minimum": 0 },
          "overloaded": { "type": "boolean" },
          "outage": { "type": "boolean" },
          "reroute_route_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } }
        }
      }
    },
    "failure_zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "origin", "radius", "severity", "affected_route_ids", "affected_deck_count"],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "origin": { "$ref": "#/$defs/point3" },
          "radius": { "type": "integer", "minimum": 0 },
          "severity": { "type": "number", "minimum": 0, "maximum": 1 },
          "affected_route_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "affected_deck_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "rule_packs": {
      "type": "array",
      "minItems": 1
    },
    "path_analysis": {
      "type": "object",
      "required": [
        "guaranteed_service_to_skyline",
        "alternate_path_count",
        "vertical_transfer_count",
        "reachable_landmark_count",
        "main_path_room_reachability",
        "quality_score"
      ],
      "properties": {
        "guaranteed_service_to_skyline": {
          "const": true
        },
        "alternate_path_count": {
          "type": "integer",
          "minimum": 3
        },
        "vertical_transfer_count": {
          "type": "integer",
          "minimum": 3
        },
        "reachable_landmark_count": {
          "type": "integer",
          "minimum": 8
        },
        "main_path_room_reachability": {
          "type": "number",
          "minimum": 1
        },
        "quality_score": {
          "type": "number",
          "minimum": 0.75,
          "maximum": 1
        }
      }
    }
  },
  "$defs": {
    "point3": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 }
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "room": {
      "type": "object",
      "required": ["id", "position", "district", "label"],
      "properties": {
        "id": { "type": "integer", "minimum": 0 },
        "position": { "$ref": "#/$defs/point3" },
        "district": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "route": {
      "type": "object",
      "required": ["id", "kind", "role", "start_node", "end_node", "points", "length", "stratum"],
      "properties": {
        "id": { "type": "integer", "minimum": 0 },
        "kind": { "type": "string" },
        "role": { "type": "string" },
        "start_node": { "type": "integer", "minimum": 0 },
        "end_node": { "type": "integer", "minimum": 0 },
        "points": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/point3" }
        },
        "length": { "type": "integer", "minimum": 1 },
        "stratum": { "type": "string" }
      }
    }
  }
}
