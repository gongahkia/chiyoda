{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gibson.local/schemas/scenario.schema.json",
  "title": "Gibson Scenario",
  "type": "object",
  "required": [
    "schema_version",
    "seed",
    "profile",
    "typology",
    "title",
    "start",
    "goal",
    "objective_route_ids",
    "objective_room_ids",
    "hazard_ids",
    "faction_conflicts",
    "landmarks",
    "objective_chains",
    "route_constraints",
    "faction_choices",
    "hazard_timings",
    "resource_objectives",
    "dynamic_events",
    "entity_objectives",
    "typology_objectives",
    "scenario_consequences",
    "difficulty_score",
    "estimated_duration_minutes",
    "risk_breakdown",
    "balance_notes",
    "failure_states",
    "alternate_endings"
  ],
  "properties": {
    "schema_version": {
      "const": "gibson.scenario.v6"
    },
    "seed": {
      "type": "string",
      "pattern": "^[A-Z0-9]{8}$"
    },
    "profile": {
      "type": "string"
    },
    "typology": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "start": {
      "$ref": "#/$defs/point3"
    },
    "goal": {
      "$ref": "#/$defs/point3"
    },
    "objective_route_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 0 }
    },
    "objective_room_ids": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    },
    "hazard_ids": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    },
    "faction_conflicts": {
      "type": "array"
    },
    "landmarks": {
      "type": "array",
      "minItems": 1
    },
    "objective_chains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "route_ids", "room_ids", "landmark_ids", "required"]
      }
    },
    "route_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["route_id", "constraint", "pressure"],
        "properties": {
          "route_id": { "type": "integer", "minimum": 0 },
          "constraint": { "type": "string" },
          "pressure": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "faction_choices": {
      "type": "array"
    },
    "hazard_timings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["hazard_id", "phase", "cycle_hour", "severity"],
        "properties": {
          "hazard_id": { "type": "integer", "minimum": 0 },
          "phase": { "type": "string" },
          "cycle_hour": { "type": "integer", "minimum": 0, "maximum": 23 },
          "severity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "resource_objectives": {
      "type": "array",
      "minItems": 1
    },
    "dynamic_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "pressure_field_id",
          "layout_mutation_id",
          "phase_id",
          "affected_route_ids",
          "affected_room_ids",
          "intensity"
        ],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "label": { "type": "string" },
          "pressure_field_id": { "type": "integer", "minimum": 0 },
          "layout_mutation_id": { "type": ["integer", "null"], "minimum": 0 },
          "phase_id": { "type": ["integer", "null"], "minimum": 0 },
          "affected_route_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "affected_room_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "intensity": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "entity_objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "entity_id", "path_id", "route_ids", "required"],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "label": { "type": "string" },
          "entity_id": { "type": "integer", "minimum": 0 },
          "path_id": { "type": "integer", "minimum": 0 },
          "route_ids": { "type": "array", "minItems": 1, "items": { "type": "integer", "minimum": 0 } },
          "required": { "type": "boolean" }
        }
      }
    },
    "typology_objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "typology", "route_ids", "hazard_ids", "room_ids", "required"],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "label": { "type": "string" },
          "typology": { "type": "string" },
          "route_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "hazard_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "room_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "required": { "type": "boolean" }
        }
      }
    },
    "scenario_consequences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "label", "route_ids", "room_ids", "hazard_ids", "layout_mutation_id", "reversible"],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "kind": { "type": "string" },
          "label": { "type": "string" },
          "route_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "room_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "hazard_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
          "layout_mutation_id": { "type": ["integer", "null"], "minimum": 0 },
          "reversible": { "type": "boolean" }
        }
      }
    },
    "difficulty_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "estimated_duration_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "risk_breakdown": {
      "type": "object",
      "required": [
        "route_risk",
        "hazard_risk",
        "faction_risk",
        "resource_risk",
        "dynamic_risk",
        "objective_complexity"
      ],
      "properties": {
        "route_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "hazard_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "faction_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "resource_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "dynamic_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "objective_complexity": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "balance_notes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "failure_states": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "alternate_endings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "condition", "consequence"]
      }
    }
  },
  "$defs": {
    "point3": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 }
      ],
      "minItems": 3,
      "maxItems": 3
    }
  }
}
